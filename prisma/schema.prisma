generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique @db.VarChar(50)
  password  String   @db.VarChar(255)
  nama      String?  @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("admin")
}

model ProfilDesa {
  id                 Int      @id @default(autoincrement())
  namaDesa           String   @map("nama_desa") @db.VarChar(100)
  kecamatan          String?  @db.VarChar(100)
  kabupaten          String?  @db.VarChar(100)
  provinsi           String?  @db.VarChar(100)
  alamat             String?
  kodePos            String?  @map("kode_pos") @db.VarChar(10)
  email              String?  @db.VarChar(100)
  telepon            String?  @db.VarChar(30)
  whatsapp           String?  @db.VarChar(30)
  deskripsi          String?
  visi               String?
  misi               String?
  logo               String?  @db.VarChar(255)
  fotoKantor         String?  @map("foto_kantor") @db.VarChar(255)
  mapsEmbed          String?  @map("maps_embed")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")
  strukturOrganisasi String?  @map("struktur_organisasi") @db.VarChar(255)

  @@map("profil_desa")
}

model VideoProfil {
  id        Int                  @id @default(autoincrement())
  judul     String               @db.VarChar(150)
  deskripsi String?
  urlVideo  String               @map("url_video") @db.VarChar(255)
  thumbnail String?              @db.VarChar(255)
  status    video_profil_status? @default(aktif)
  createdAt DateTime             @default(now()) @map("created_at")
  updatedAt DateTime             @default(now()) @updatedAt @map("updated_at")

  @@map("video_profil")
}

model JamPelayanan {
  id         Int       @id @default(autoincrement())
  hari       String    @db.VarChar(100)
  jamBuka    DateTime? @map("jam_buka") @db.Time(6)
  jamTutup   DateTime? @map("jam_tutup") @db.Time(6)
  keterangan String?   @db.VarChar(100)
  urutan     Int?      @default(0)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at")

  @@map("jam_pelayanan")
}

model Kegiatan {
  id        Int              @id @default(autoincrement())
  judul     String           @db.VarChar(200)
  slug      String?          @unique @db.VarChar(220)
  tanggal   DateTime         @db.Date
  lokasi    String?          @db.VarChar(150)
  kategori  String?          @db.VarChar(100)
  ringkasan String?
  isi       String?
  gambar    String?          @db.VarChar(255)
  status    kegiatan_status? @default(draft)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @default(now()) @updatedAt @map("updated_at")

  @@map("kegiatan")
}

model LembagaDesa {
  id          Int                  @id @default(autoincrement())
  namaLembaga String               @map("nama_lembaga") @db.VarChar(150)
  singkatan   String?              @db.VarChar(50)
  deskripsi   String?
  ketua       String?              @db.VarChar(100)
  periode     String?              @db.VarChar(50)
  ikon        String?              @db.VarChar(255)
  foto        String?              @db.VarChar(255)
  status      lembaga_desa_status? @default(aktif)
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @default(now()) @updatedAt @map("updated_at")
  anggota     AnggotaLembaga[]

  @@map("lembaga_desa")
}

model AnggotaLembaga {
  id        Int         @id @default(autoincrement())
  lembagaId Int         @map("lembaga_id")
  nama      String      @db.VarChar(100)
  jabatan   String?     @db.VarChar(100)
  foto      String?     @db.VarChar(255)
  urutan    Int?        @default(0)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @default(now()) @updatedAt @map("updated_at")
  lembaga   LembagaDesa @relation(fields: [lembagaId], references: [id], onDelete: Cascade, map: "fk_anggota_lembaga")

  @@index([lembagaId])
  @@map("anggota_lembaga")
}

model ProdukHukum {
  id                Int                  @id @default(autoincrement())
  jenis             produk_hukum_jenis
  nomor             String               @db.VarChar(100)
  tahun             Int
  judul             String               @db.VarChar(255)
  tanggalDitetapkan DateTime?            @map("tanggal_ditetapkan") @db.Date
  fileDokumen       String?              @map("file_dokumen") @db.VarChar(255)
  keterangan        String?
  status            produk_hukum_status? @default(publish)
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @default(now()) @updatedAt @map("updated_at")

  @@map("produk_hukum")
}

model LayananDesa {
  id            Int                  @id @default(autoincrement())
  namaLayanan   String               @map("nama_layanan") @db.VarChar(150)
  deskripsi     String?
  persyaratan   String?
  ikon          String?              @db.VarChar(255)
  status        layanan_desa_status? @default(aktif)
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @default(now()) @updatedAt @map("updated_at")
  kategori      String               @default("Umum") @db.VarChar(100)
  tampilanBesar Boolean              @default(false) @map("tampilan_besar")
  urutan        Int                  @default(0)

  @@map("layanan_desa")
}

model KontakDesa {
  id         Int               @id @default(autoincrement())
  namaKontak String            @map("nama_kontak") @db.VarChar(100)
  jabatan    String?           @db.VarChar(100)
  telepon    String?           @db.VarChar(30)
  email      String?           @db.VarChar(100)
  alamat     String?
  tipe       kontak_desa_tipe? @default(Kantor_Desa)
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @default(now()) @updatedAt @map("updated_at")

  @@map("kontak_desa")
}

model PerangkatDesa {
  id        Int       @id @default(autoincrement())
  nama      String    @db.VarChar(100)
  jabatan   String    @db.VarChar(150)
  foto      String?   @db.VarChar(255)
  urutan    Int?      @default(0)
  status    String?   @default("aktif") @db.VarChar(20)
  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@map("perangkat_desa")
}

enum jenis_produk_hukum_enum {
  Perdes
  Perkades
  SK_Kades      @map("SK Kades")
  Keputusan_BPD @map("Keputusan BPD")
  APBDes
  RKPDes
  Lainnya
}

enum kegiatan_status {
  draft
  publish
}

enum kontak_desa_tipe {
  Kantor_Desa    @map("Kantor Desa")
  Perangkat_Desa @map("Perangkat Desa")
  Layanan
  Lainnya
}

enum layanan_desa_status {
  aktif
  nonaktif
}

enum lembaga_desa_status {
  aktif
  nonaktif
}

enum produk_hukum_jenis {
  Perdes
  Perkades
  SK_Kades      @map("SK Kades")
  Keputusan_BPD @map("Keputusan BPD")
  APBDes
  RKPDes
  Lainnya
}

enum produk_hukum_status {
  draft
  publish
}

enum status_aktif_enum {
  aktif
  nonaktif
}

enum status_draft_enum {
  draft
  publish
}

enum tipe_kontak_enum {
  Kantor_Desa    @map("Kantor Desa")
  Perangkat_Desa @map("Perangkat Desa")
  Layanan
  Lainnya
}

enum video_profil_status {
  aktif
  nonaktif
}
